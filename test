<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jujuy Básquet · Dashboard de Rendimiento 2026</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500&display=swap');

        :root {
            --bg: #0d0f14;
            --surface: #161920;
            --surface2: #1e2230;
            --border: rgba(255,255,255,0.07);
            --border2: rgba(255,255,255,0.12);
            --accent: #e8c84a;
            --accent2: #4ab8e8;
            --text: #f0eee8;
            --text2: #9a9890;
            --text3: #5a5856;
            --green: #4ae87a;
            --orange: #e87a4a;
            --red: #e84a4a;
            --mono: 'DM Mono', monospace;
            --head: 'Barlow Condensed', sans-serif;
            --body: 'Barlow', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body { 
            background: var(--bg); 
            color: var(--text); 
            font-family: var(--body); 
            font-size: 14px; 
            line-height: 1.5; 
            min-height: 100vh; 
        }

        /* HEADER */
        .site-header { 
            background: var(--surface); 
            border-bottom: 1px solid var(--border2); 
            padding: 16px 24px; 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            position: sticky; 
            top: 0; 
            z-index: 100; 
        }

        .site-logo { 
            font-family: var(--head); 
            font-size: 22px; 
            font-weight: 800; 
            letter-spacing: .02em; 
            color: var(--accent); 
            text-transform: uppercase; 
        }

        /* TABS */
        .main-tabs { 
            display: flex; 
            justify-content: center; 
            background: var(--bg); 
            padding: 15px 0; 
            gap: 10px; 
            border-bottom: 1px solid var(--border); 
        }

        .tab-btn { 
            padding: 8px 20px; 
            border-radius: 20px; 
            border: 1px solid var(--border2); 
            background: var(--surface); 
            color: var(--text2); 
            font-family: var(--head); 
            font-weight: 700; 
            cursor: pointer; 
            text-transform: uppercase; 
            transition: 0.3s; 
        }

        .tab-btn.active { background: var(--accent); color: var(--bg); border-color: var(--accent); }

        /* PLAYER NAV */
        .player-nav { 
            background: var(--surface); 
            border-bottom: 1px solid var(--border); 
            padding: 0 24px; 
            display: flex; 
            gap: 4px; 
            overflow-x: auto; 
            scrollbar-width: none; 
        }

        .player-btn { 
            font-family: var(--head); 
            font-size: 13px; 
            font-weight: 600; 
            color: var(--text3); 
            background: none; 
            border: none; 
            border-bottom: 2px solid transparent; 
            padding: 12px 14px; 
            cursor: pointer; 
            white-space: nowrap; 
        }

        .player-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

        .main { padding: 24px; max-width: 1200px; margin: 0 auto; }
        .hidden { display: none !important; }

        /* CARDS & GRID */
        .player-header { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .player-avatar { width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--head); font-size: 20px; font-weight: 800; border: 2px solid var(--border2); flex-shrink: 0; }
        .player-info h1 { font-family: var(--head); font-size: 32px; font-weight: 800; text-transform: uppercase; line-height: 1; }
        .player-info h1 span { color: var(--accent); }
        
        .kpi-strip { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; margin-bottom: 20px; }
        .kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 14px 12px; text-align: center; }
        .kpi-val { font-family: var(--head); font-size: 26px; font-weight: 700; }
        .kpi-lbl { font-family: var(--mono); font-size: 10px; color: var(--text3); text-transform: uppercase; }

        .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
        .scard { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 18px; position: relative; }
        .scard-title { font-family: var(--head); font-size: 11px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--text3); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
        .scard-title::before { content: ''; width: 3px; height: 12px; background: var(--accent); border-radius: 2px; }

        /* BARS & STATS */
        .pos-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .pos-lbl { font-family: var(--mono); font-size: 11px; color: var(--text2); width: 80px; }
        .pos-track { flex: 1; height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
        .pos-bar { height: 100%; border-radius: 3px; }
        
        .zona-row { display: grid; grid-template-columns: 80px 1fr 70px 70px 70px; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--border); align-items: center; }
        .zona-val { font-family: var(--mono); font-size: 11px; text-align: right; }

        /* RENOVATION BADGES */
        .renov-badge { padding: 4px 10px; border-radius: 4px; font-family: var(--head); font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .renov-si { background: rgba(74,232,122,0.1); color: var(--green); border: 1px solid rgba(74,232,122,0.2); }
        .renov-no { background: rgba(232,74,74,0.1); color: var(--red); border: 1px solid rgba(232,74,74,0.2); }
        .renov-cond { background: rgba(74,184,232,0.1); color: var(--accent2); border: 1px solid rgba(74,184,232,0.2); }

        .verdict-section { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .verdict-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 18px; }
        .verdict-item { font-size: 12px; color: var(--text2); margin-bottom: 6px; display: flex; gap: 8px; }
        .verdict-item::before { content: '→'; color: var(--text3); }

        .summary-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px; }

        @media(max-width: 700px) {
            .grid2, .verdict-section, .kpi-strip { grid-template-columns: 1fr; }
            .kpi-strip { grid-template-columns: repeat(3, 1fr); }
        }
    </style>
</head>
<body>

    <header class="site-header">
        <div class="site-logo">JUJUY BÁSQUET <span>· 360° ANALYTICS</span></div>
        <div style="font-family: var(--mono); font-size: 10px; color: var(--text3);">VERSIÓN 2026.04</div>
    </header>

    <div class="main-tabs">
        <button class="tab-btn active" onclick="switchTab('perfiles')">Perfiles Detallados</button>
        <button class="tab-btn" onclick="switchTab('resumen')">Resumen Ejecutivo</button>
    </div>

    <div id="view-perfiles">
        <nav class="player-nav" id="playerNav"></nav>
        <main class="main" id="mainContent"></main>
    </div>

    <div id="view-resumen" class="main hidden">
        <div class="summary-grid" id="summaryGrid"></div>
    </div>

<script>
const PLAYERS = [
    {
        id: 'stehli', name: 'Stehli', initials: 'RS', avatarBg: '#1a2a3a', avatarColor: '#4ab8e8',
        pj: 32, min: 31.0, pts: 13.5, plays: 16.5, usg: 24.0, efg: 44.6, val: 12.1, ppp: 0.82,
        t2c:2.9, t2i:6.8, t2pct:42.6, t3c:1.8, t3i:5.7, t3pct:31.3, t1c:2.4, t1i:4.1, t1pct:59.5,
        ptsPct: 95, playsPct: 98, efgPct: 55, pppPct: 45,
        posEquipo: { pts: 'ÉLITE', plays: 'ÉLITE', efg: 'PROM', ppp: 'PROM' },
        localPts: 14.2, localEfg: 46.1, localVal: 13.8, visitPts: 12.8, visitEfg: 43.1, visitVal: 10.4,
        bloques: [[12,45,13],[11,41,10],[14,48,16],[13,44,14],[11,40,10],[16,48,16],[13,43,13],[15,46,15]],
        favor: ['Líder en volumen de juego', 'Capacidad de anotación bajo presión'],
        condiciones: ['Mejorar efectividad en libres', 'Gestionar fatiga en cierres'],
        renovacion: 'si', renovLabel: 'SÍ, RENOVAR'
    },
    {
        id: 'ibarra', name: 'Ibarra', initials: 'SI', avatarBg: '#2a3a1a', avatarColor: '#4ae87a',
        pj: 31, min: 26.3, pts: 13.2, plays: 11.7, usg: 20.1, efg: 58.4, val: 10.9, ppp: 1.13,
        t2c:1.9, t2i:2.9, t2pct:63.7, t3c:2.6, t3i:7.1, t3pct:37.4, t1c:1.5, t1i:2.3, t1pct:65.8,
        ptsPct: 92, playsPct: 60, efgPct: 95, pppPct: 98,
        posEquipo: { pts: 'ÉLITE', plays: 'PROM', efg: 'ÉLITE', ppp: 'ÉLITE' },
        localPts: 14.5, localEfg: 61.2, localVal: 12.1, visitPts: 12.0, visitEfg: 55.4, visitVal: 9.8,
        bloques: [[11,54,9],[14,60,11],[12,58,10],[13,59,12],[10,50,8],[16,65,14],[15,58,13],[14,62,12]],
        favor: ['Máxima eficiencia (PPP 1.13)', 'Amenaza de tres puntos constante'],
        condiciones: ['Aumentar participación en momentos clave'],
        renovacion: 'si', renovLabel: 'SÍ, RENOVAR'
    }
];

let activeId = PLAYERS[0].id;
let currentCharts = [];

function switchTab(tab) {
    document.getElementById('view-perfiles').classList.toggle('hidden', tab !== 'perfiles');
    document.getElementById('view-resumen').classList.toggle('hidden', tab !== 'resumen');
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.innerText.toLowerCase().includes(tab)));
    if(tab === 'resumen') renderSummary();
}

function setActive(id) {
    activeId = id;
    renderNav();
    renderDetails();
}

function renderNav() {
    const nav = document.getElementById('playerNav');
    nav.innerHTML = PLAYERS.map(p => `
        <button class="player-btn ${p.id === activeId ? 'active' : ''}" onclick="setActive('${p.id}')">
            ${p.name.toUpperCase()}
        </button>
    `).join('');
}

function renderDetails() {
    currentCharts.forEach(c => c.destroy());
    const p = PLAYERS.find(x => x.id === activeId);
    document.getElementById('mainContent').innerHTML = buildHTML(p);
    buildCharts(p);
}

function renderSummary() {
    const grid = document.getElementById('summaryGrid');
    grid.innerHTML = PLAYERS.map(p => `
        <div class="scard">
            <div class="scard-title">${p.name}</div>
            <div style="font-family: var(--mono); font-size: 11px; display:grid; grid-template-columns: 1fr 1fr; gap:5px;">
                <span>PTS: ${p.pts}</span><span>eFG%: ${p.efg}%</span>
                <span>PPP: ${p.ppp}</span><span>VAL: ${p.val}</span>
            </div>
            <div style="margin-top:12px">
                <span class="renov-badge ${p.renovacion === 'si' ? 'renov-si' : 'renov-cond'}">${p.renovLabel}</span>
            </div>
        </div>
    `).join('');
}

function buildHTML(p) {
    const totalTiros = p.t2i + p.t3i + p.t1i;
    const t2p = (p.t2i/totalTiros*100).toFixed(1);
    const t3p = (p.t3i/totalTiros*100).toFixed(1);
    const t1p = (p.t1i/totalTiros*100).toFixed(1);

    return `
    <div class="player-header">
        <div class="player-avatar" style="background:${p.avatarBg};color:${p.avatarColor}">${p.initials}</div>
        <div class="player-info">
            <h1>${p.name}</h1>
            <div class="renov-badge ${p.renovacion === 'si' ? 'renov-si' : 'renov-cond'}">${p.renovLabel}</div>
        </div>
    </div>

    <div class="kpi-strip">
        <div class="kpi"><div class="kpi-val">${p.min}</div><div class="kpi-lbl">MIN</div></div>
        <div class="kpi" style="color:var(--accent)"><div class="kpi-val">${p.pts}</div><div class="kpi-lbl">PTS</div></div>
        <div class="kpi"><div class="kpi-val">${p.usg}%</div><div class="kpi-lbl">USG%</div></div>
        <div class="kpi" style="color:var(--green)"><div class="kpi-val">${p.efg}%</div><div class="kpi-lbl">eFG%</div></div>
        <div class="kpi"><div class="kpi-val">${p.ppp}</div><div class="kpi-lbl">PPP</div></div>
        <div class="kpi"><div class="kpi-val">${p.val}</div><div class="kpi-lbl">VAL</div></div>
    </div>

    <div class="grid2">
        <div class="scard">
            <div class="scard-title">Posición Equipo</div>
            <div class="pos-row"><span class="pos-lbl">PTS</span><div class="pos-track"><div class="pos-bar" style="width:${p.ptsPct}%;background:var(--accent)"></div></div></div>
            <div class="pos-row"><span class="pos-lbl">PLAYS</span><div class="pos-track"><div class="pos-bar" style="width:${p.playsPct}%;background:var(--accent2)"></div></div></div>
        </div>
        <div class="scard">
            <div class="scard-title">Evolución Bloques</div>
            <div style="height:150px"><canvas id="blockChart"></canvas></div>
        </div>
    </div>

    <div class="scard" style="margin-bottom:16px">
        <div class="scard-title">Distribución de Tiro</div>
        <div class="zona-row"><span>TRIPLE</span><div class="pos-track"><div class="pos-bar" style="width:${t3p}%;background:var(--accent2)"></div></div><span class="zona-val">${p.t3pct}%</span><span class="zona-val">${(p.t3pct/100*3).toFixed(2)}</span><span class="zona-val">${p.t3c}/${p.t3i}</span></div>
        <div class="zona-row"><span>DOBLE</span><div class="pos-track"><div class="pos-bar" style="width:${t2p}%;background:var(--accent)"></div></div><span class="zona-val">${p.t2pct}%</span><span class="zona-val">${(p.t2pct/100*2).toFixed(2)}</span><span class="zona-val">${p.t2c}/${p.t2i}</span></div>
    </div>

    <div class="verdict-section">
        <div class="verdict-card"><div class="scard-title" style="color:var(--green)">Fortalezas</div>${p.favor.map(f => `<div class="verdict-item">${f}</div>`).join('')}</div>
        <div class="verdict-card"><div class="scard-title" style="color:var(--orange)">A Mejorar</div>${p.condiciones.map(c => `<div class="verdict-item">${c}</div>`).join('')}</div>
    </div>`;
}

function buildCharts(p) {
    const ctx = document.getElementById('blockChart');
    const chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['B1','B2','B3','B4','B5','B6','B7','B8'],
            datasets: [{ label: 'VAL', data: p.bloques.map(b => b[2]), borderColor: '#e8c84a', tension: 0.3, fill: true, backgroundColor: 'rgba(232,200,74,0.05)' }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { display: false }, x: { grid: { display: false } } } }
    });
    currentCharts.push(chart);
}

renderNav();
renderDetails();
</script>
</body>
</html>
